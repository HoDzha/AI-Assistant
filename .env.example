OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
DATABASE_URL=sqlite:///./data/freelance_flow.db
OPENAI_CACHE_BACKEND=persistent
OPENAI_CACHE_FILE=./data/analysis_cache.db
OPENAI_CACHE_TTL_SECONDS=3600
OPENAI_CACHE_MAX_ENTRIES=256
LOG_LEVEL=INFO
